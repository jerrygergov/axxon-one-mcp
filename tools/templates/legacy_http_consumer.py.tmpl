#!/usr/bin/env python3
"""Generated HTTP consumer for $VERB $PATH (auth=$AUTH_MODE)."""

from __future__ import annotations

import json
import logging
import os
import sys

DURATION_SECONDS = $DURATION
BYTE_CAP = $BYTE_CAP
PATH = "$PATH"
VERB = "$VERB"
AUTH_MODE = "$AUTH_MODE"

REQUIRED_ENV = ("AXXON_HTTP_URL", "AXXON_USERNAME", "AXXON_PASSWORD")


def redact(value: str) -> str:
    if not value:
        return ""
    return value[:2] + "***"


def fetch_bearer(base: str, auth: tuple[str, str], timeout: int) -> str:
    response = requests.post(
        base + "/grpc",
        auth=auth,
        json={
            "method": "axxonsoft.bl.auth.AuthenticationService.AuthenticateEx2",
            "data": {"user_name": auth[0], "password": auth[1]},
        },
        timeout=timeout,
    )
    response.raise_for_status()
    token = response.json().get("token_value")
    if not token:
        raise RuntimeError("no token_value in /grpc auth response")
    return token


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(asctime)s %(levelname)s %(message)s")
    missing = [name for name in REQUIRED_ENV if not os.environ.get(name)]
    if missing:
        logging.error("missing env: %s", ",".join(missing))
        return 2
    global requests
    import requests

    base = os.environ["AXXON_HTTP_URL"].rstrip("/")
    user = os.environ["AXXON_USERNAME"]
    password = os.environ["AXXON_PASSWORD"]
    logging.info("user=%s password=%s base=%s path=%s", user, redact(password), base, PATH)

    headers: dict[str, str] = {}
    request_auth = None
    if AUTH_MODE == "bearer":
        headers["Authorization"] = "Bearer " + fetch_bearer(base, (user, password), DURATION_SECONDS)
    else:
        request_auth = (user, password)

    response = requests.request(VERB, base + PATH, headers=headers, auth=request_auth, timeout=DURATION_SECONDS)
    body = response.content[:BYTE_CAP]
    logging.info("status=%s bytes=%d", response.status_code, len(body))
    print(json.dumps({"path": PATH, "status": response.status_code, "bytes": len(body)}))
    return 0 if response.ok else 1


if __name__ == "__main__":
    sys.exit(main())
