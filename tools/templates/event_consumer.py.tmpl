#!/usr/bin/env python3
"""Generated bounded event consumer for $SUBJECT."""

from __future__ import annotations

import json
import logging
import os
import sys
import time

DURATION_SECONDS = $DURATION
COUNT_CAP = $COUNT
SUBJECT = "$SUBJECT"
APPDATA_HINT = $APPDATA_HINT

REQUIRED_ENV = ("AXXON_HOST", "AXXON_TLS_CN", "AXXON_USERNAME", "AXXON_PASSWORD")


def redact(value: str) -> str:
    if not value:
        return ""
    return value[:2] + "***"


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(asctime)s %(levelname)s %(message)s")
    missing = [name for name in REQUIRED_ENV if not os.environ.get(name)]
    if missing:
        logging.error("missing env: %s", ",".join(missing))
        return 2
    if APPDATA_HINT:
        logging.info(
            "subject %s is a parent AVDetector; semantic analytics live on AppDataDetector children",
            SUBJECT,
        )
    sys.path.insert(0, os.environ.get("AXXON_STUBS_PATH", "/tmp/axxon-grpc-py"))
    import grpc
    from axxonsoft.bl.security.Authentication_pb2 import AuthenticateEx2Request
    from axxonsoft.bl.security.Authentication_pb2_grpc import AuthenticationServiceStub
    from axxonsoft.bl.events.Events_pb2 import PullEventsRequest, SearchFilterArray
    from axxonsoft.bl.events.Events_pb2_grpc import DomainNotifierStub

    host = os.environ["AXXON_HOST"]
    tls_cn = os.environ["AXXON_TLS_CN"]
    user = os.environ["AXXON_USERNAME"]
    logging.info("user=%s password=%s host=%s subject=%s", user, redact(os.environ["AXXON_PASSWORD"]), host, SUBJECT)

    creds = grpc.ssl_channel_credentials()
    options = (("grpc.ssl_target_name_override", tls_cn),)
    received = 0
    deadline = time.time() + DURATION_SECONDS
    with grpc.secure_channel(host, creds, options=options) as channel:
        auth = AuthenticationServiceStub(channel)
        token = auth.AuthenticateEx2(
            AuthenticateEx2Request(username=user, password=os.environ["AXXON_PASSWORD"]),
            timeout=DURATION_SECONDS,
        ).access_token
        metadata = (("authorization", "Bearer " + token),)
        notifier = DomainNotifierStub(channel)
        request = PullEventsRequest(filters=[SearchFilterArray(subjects=[SUBJECT])])
        try:
            for event in notifier.PullEvents(request, timeout=DURATION_SECONDS, metadata=metadata):
                received += 1
                logging.info("event %d subject=%s", received, SUBJECT)
                if received >= COUNT_CAP or time.time() >= deadline:
                    break
        except grpc.RpcError as exc:
            logging.warning("rpc closed: %s", exc.code())
    print(json.dumps({"subject": SUBJECT, "received": received, "duration_cap": DURATION_SECONDS, "count_cap": COUNT_CAP}))
    return 0


if __name__ == "__main__":
    sys.exit(main())
