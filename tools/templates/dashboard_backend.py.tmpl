#!/usr/bin/env python3
"""Generated read-only dashboard backend for an Axxon One server.

Collects a single dashboard snapshot from three read-safe sources and writes it as
JSON to OUTPUT_PATH: DomainService.ListCameras, LogicService.GetActiveAlerts, and
EventHistoryService.ReadEvents (recent window). No mutation, no streaming server; the
serialised snapshot is bounded by BYTE_CAP. Suitable as a polling backend for a dashboard.
"""

from __future__ import annotations

import json
import logging
import os
import sys
import time

DURATION_SECONDS = 60
BYTE_CAP = $BYTE_CAP
OUTPUT_PATH = "$OUTPUT_PATH"
EVENTS_WINDOW_SECONDS = 3600

REQUIRED_ENV = ("AXXON_HOST", "AXXON_TLS_CN", "AXXON_USERNAME", "AXXON_PASSWORD")


def redact(value: str) -> str:
    if not value:
        return ""
    return value[:2] + "***"


def load_ca() -> bytes | None:
    ca_path = os.environ.get("AXXON_CA")
    if ca_path and os.path.isfile(ca_path):
        with open(ca_path, "rb") as fh:
            return fh.read()
    return None


def message_to_dict(message) -> dict:
    from google.protobuf.json_format import MessageToDict
    return MessageToDict(message, preserving_proto_field_name=True)


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(asctime)s %(levelname)s %(message)s")
    missing = [name for name in REQUIRED_ENV if not os.environ.get(name)]
    if missing:
        logging.error("missing env: %s", ",".join(missing))
        return 2
    sys.path.insert(0, os.environ.get("AXXON_STUBS_PATH", "/tmp/axxon-grpc-py"))
    import grpc
    from axxonsoft.bl.auth.Authentication_pb2 import AuthenticateRequest
    from axxonsoft.bl.auth.Authentication_pb2_grpc import AuthenticationServiceStub
    from axxonsoft.bl.domain.Domain_pb2 import ListCamerasRequest
    from axxonsoft.bl.domain.Domain_pb2_grpc import DomainServiceStub
    from axxonsoft.bl.events.EventHistory_pb2 import ReadEventsRequest, SearchFilter, SearchFilterArray
    from axxonsoft.bl.events.EventHistory_pb2_grpc import EventHistoryServiceStub
    from axxonsoft.bl.logic.LogicService_pb2 import GetActiveAlertsRequest
    from axxonsoft.bl.logic.LogicService_pb2_grpc import LogicServiceStub
    from axxonsoft.bl.primitive.Primitives_pb2 import TimeRange

    host = os.environ["AXXON_HOST"]
    tls_cn = os.environ["AXXON_TLS_CN"]
    user = os.environ["AXXON_USERNAME"]
    logging.info("user=%s password=%s host=%s output=%s", user, redact(os.environ["AXXON_PASSWORD"]), host, OUTPUT_PATH)

    ca = load_ca()
    base_creds = grpc.ssl_channel_credentials(root_certificates=ca) if ca else grpc.ssl_channel_credentials()
    options = (("grpc.ssl_target_name_override", tls_cn),)

    with grpc.secure_channel(host, base_creds, options=options) as auth_channel:
        token = AuthenticationServiceStub(auth_channel).AuthenticateEx2(
            AuthenticateRequest(user_name=user, password=os.environ["AXXON_PASSWORD"]),
            timeout=DURATION_SECONDS,
        )
        if token.error_code != 0:
            logging.error("auth failed error_code=%s", token.error_code)
            return 3
    metadata_pair = ((token.token_name, token.token_value),)
    auth_creds = grpc.metadata_call_credentials(lambda _ctx, cb: cb(metadata_pair, None))
    composite = grpc.composite_channel_credentials(base_creds, auth_creds)

    snapshot: dict = {
        "timestamp_ms": int(time.time() * 1000),
        "host": host,
        "cameras": [],
        "active_alerts": [],
        "recent_events": [],
    }
    bytes_total = 0
    with grpc.secure_channel(host, composite, options=options) as channel:
        domain = DomainServiceStub(channel)
        for response in domain.ListCameras(ListCamerasRequest(view=0), timeout=DURATION_SECONDS):
            for camera in response.items:
                entry = message_to_dict(camera)
                bytes_total += len(json.dumps(entry))
                snapshot["cameras"].append(entry)
                if bytes_total >= BYTE_CAP:
                    break
            if bytes_total >= BYTE_CAP:
                break

        if bytes_total < BYTE_CAP:
            logic = LogicServiceStub(channel)
            for camera in snapshot["cameras"]:
                camera_ap = camera.get("access_point", "")
                if not camera_ap or bytes_total >= BYTE_CAP:
                    break
                try:
                    alerts = logic.GetActiveAlerts(GetActiveAlertsRequest(camera_ap=camera_ap), timeout=DURATION_SECONDS)
                except grpc.RpcError as exc:
                    logging.warning("GetActiveAlerts(%s) closed: %s", camera_ap, exc.code())
                    continue
                for alert in getattr(alerts, "alerts", []):
                    entry = message_to_dict(alert)
                    bytes_total += len(json.dumps(entry))
                    snapshot["active_alerts"].append(entry)
                    if bytes_total >= BYTE_CAP:
                        break

        if bytes_total < BYTE_CAP:
            now_ms = int(time.time() * 1000)
            range_msg = TimeRange(begin_time=str(now_ms - EVENTS_WINDOW_SECONDS * 1000), end_time=str(now_ms))
            filters = SearchFilterArray(filters=[SearchFilter()])
            try:
                for response in EventHistoryServiceStub(channel).ReadEvents(
                    ReadEventsRequest(range=range_msg, filters=filters), timeout=DURATION_SECONDS
                ):
                    for item in response.items:
                        entry = message_to_dict(item)
                        bytes_total += len(json.dumps(entry))
                        snapshot["recent_events"].append(entry)
                        if bytes_total >= BYTE_CAP:
                            break
                    if bytes_total >= BYTE_CAP:
                        break
            except grpc.RpcError as exc:
                logging.warning("ReadEvents closed: %s", exc.code())

    output_path = os.path.expanduser(OUTPUT_PATH)
    os.makedirs(os.path.dirname(output_path) or ".", exist_ok=True)
    with open(output_path, "w", encoding="utf-8") as fh:
        json.dump(snapshot, fh, indent=2, sort_keys=True)
    print(json.dumps({
        "output": output_path,
        "cameras": len(snapshot["cameras"]),
        "active_alerts": len(snapshot["active_alerts"]),
        "recent_events": len(snapshot["recent_events"]),
        "bytes": bytes_total,
    }))
    return 0


if __name__ == "__main__":
    sys.exit(main())
