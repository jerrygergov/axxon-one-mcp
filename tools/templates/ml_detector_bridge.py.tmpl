#!/usr/bin/env python3
"""Generated ML detector bridge for $ACCESS_POINT.

Reads a batch of external ML inference results from RESULTS_PATH (a JSON list) and
raises one external detector event per result via
ExternalDetectorService.RaiseOccasionalEvent. The batch is bounded by COUNT_CAP and a
DURATION_SECONDS deadline. Raising events is mutating, so the generator only emits this
bundle when mutation was explicitly authorised.
"""

from __future__ import annotations

import json
import logging
import os
import sys
import time

DURATION_SECONDS = $DURATION
COUNT_CAP = $COUNT
ACCESS_POINT = "$ACCESS_POINT"
RESULTS_PATH = "$RESULTS_PATH"

REQUIRED_ENV = ("AXXON_HOST", "AXXON_TLS_CN", "AXXON_USERNAME", "AXXON_PASSWORD")


def redact(value: str) -> str:
    if not value:
        return ""
    return value[:2] + "***"


def load_ca() -> bytes | None:
    ca_path = os.environ.get("AXXON_CA")
    if ca_path and os.path.isfile(ca_path):
        with open(ca_path, "rb") as fh:
            return fh.read()
    return None


def load_results(path: str) -> list[dict]:
    if not os.path.isfile(path):
        return []
    with open(path, "r", encoding="utf-8") as fh:
        data = json.load(fh)
    return data if isinstance(data, list) else data.get("results", [])


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(asctime)s %(levelname)s %(message)s")
    missing = [name for name in REQUIRED_ENV if not os.environ.get(name)]
    if missing:
        logging.error("missing env: %s", ",".join(missing))
        return 2
    results = load_results(RESULTS_PATH)
    if not results:
        logging.warning("no results at %s; nothing to bridge", RESULTS_PATH)
        print(json.dumps({"access_point": ACCESS_POINT, "raised": 0, "results": 0}))
        return 0
    sys.path.insert(0, os.environ.get("AXXON_STUBS_PATH", "/tmp/axxon-grpc-py"))
    import grpc
    from axxonsoft.bl.auth.Authentication_pb2 import AuthenticateRequest
    from axxonsoft.bl.auth.Authentication_pb2_grpc import AuthenticationServiceStub
    from axxonsoft.bl.detectors.ExternalDetectorService_pb2 import RaiseOccasionalEventRequest
    from axxonsoft.bl.detectors.ExternalDetectorService_pb2_grpc import ExternalDetectorServiceStub

    host = os.environ["AXXON_HOST"]
    tls_cn = os.environ["AXXON_TLS_CN"]
    user = os.environ["AXXON_USERNAME"]
    logging.info(
        "user=%s password=%s host=%s ap=%s results=%d",
        user,
        redact(os.environ["AXXON_PASSWORD"]),
        host,
        ACCESS_POINT,
        len(results),
    )

    ca = load_ca()
    base_creds = grpc.ssl_channel_credentials(root_certificates=ca) if ca else grpc.ssl_channel_credentials()
    options = (("grpc.ssl_target_name_override", tls_cn),)

    with grpc.secure_channel(host, base_creds, options=options) as auth_channel:
        token = AuthenticationServiceStub(auth_channel).AuthenticateEx2(
            AuthenticateRequest(user_name=user, password=os.environ["AXXON_PASSWORD"]),
            timeout=DURATION_SECONDS,
        )
        if token.error_code != 0:
            logging.error("auth failed error_code=%s", token.error_code)
            return 3
    metadata_pair = ((token.token_name, token.token_value),)
    auth_creds = grpc.metadata_call_credentials(lambda _ctx, cb: cb(metadata_pair, None))
    composite = grpc.composite_channel_credentials(base_creds, auth_creds)

    raised = 0
    deadline = time.time() + DURATION_SECONDS
    with grpc.secure_channel(host, composite, options=options) as channel:
        stub = ExternalDetectorServiceStub(channel)
        for result in results:
            if raised >= COUNT_CAP or time.time() >= deadline:
                break
            event_type = str(result.get("event_type", "Event1"))
            try:
                stub.RaiseOccasionalEvent(
                    RaiseOccasionalEventRequest(access_point=ACCESS_POINT, event_type=event_type),
                    timeout=DURATION_SECONDS,
                )
                raised += 1
            except grpc.RpcError as exc:
                logging.warning("raise failed for result %d: %s", raised, exc.code())
    print(json.dumps({"access_point": ACCESS_POINT, "raised": raised, "results": len(results)}))
    return 0


if __name__ == "__main__":
    sys.exit(main())
